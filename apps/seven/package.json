{
  "name": "seven",
  "version": "1.0.0-alpha.2",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "pnpm exec init-loaders && react-router dev",
    "dev:publicui": "REGISTRYCONFIG=registry-publicui.config.ts pnpm exec init-loaders && react-router dev",
    "test": "pnpm exec init-loaders && vitest --coverage",
    "start": "pnpm exec init-loaders && react-router dev",
    "build": "pnpm exec init-loaders && react-router build",
    "build:publicui": "REGISTRYCONFIG=registry-publicui.config.ts pnpm exec init-loaders && react-router build",
    "start:prod": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "typegen": "react-router typegen",
    "release": "release-it",
    "release-alpha": "release-it --preRelease=alpha",
    "prettier:fix": "prettier --write '**/*.{js,jsx,ts,tsx}'",
    "lint:fix": "eslint --max-warnings=0 './**/*.{js,jsx,ts,tsx}' --fix --no-error-on-unmatched-pattern",
    "stylelint:fix": "sh -c 'if [ -f .stylelintrc ] || [ -f .stylelintrc.json ] || [ -f .stylelintrc.js ] || [ -f .stylelintrc.cjs ] || [ -f stylelint.config.js ] || [ -f stylelint.config.cjs ] || [ -f stylelint.config.mjs ]; then stylelint '''./**/*.{css,scss,less}''' --fix --allow-empty-input; else echo \"No local stylelint config, skipping\"; fi'",
    "format": "pnpm prettier:fix && pnpm lint:fix && pnpm stylelint:fix"
  },
  "dependencies": {
    "@plone/agave": "workspace:*",
    "@plone/blocks": "workspace:*",
    "@plone/client": "workspace:*",
    "@plone/cmsui": "workspace:*",
    "@plone/components": "workspace:*",
    "@plone/helpers": "workspace:*",
    "@plone/layout": "workspace:*",
    "@plone/plate": "workspace:*",
    "@plone/publicui": "workspace:*",
    "@plone/react-router": "workspace:*",
    "@plone/registry": "workspace:*",
    "@plone/theming": "workspace:*",
    "@react-router/node": "catalog:",
    "@react-router/serve": "catalog:",
    "i18next": "^24.2.3",
    "i18next-browser-languagedetector": "^8.0.4",
    "i18next-fs-backend": "^2.6.0",
    "i18next-http-backend": "^3.0.2",
    "isbot": "^5.1.27",
    "jwt-decode": "^4.0.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-i18next": "catalog:",
    "react-router": "catalog:",
    "remix-i18next": "^7.1.0"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.27.1",
    "@plone/types": "workspace:*",
    "@react-router/dev": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "babel-plugin-react-compiler": "1.0.0",
    "release-it": "catalog:",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-babel": "^1.3.2",
    "vite-plugin-devtools-json": "^1.0.0",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22"
  }
}
