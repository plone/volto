{
  "name": "@plone/tooling",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "scripts": {
    "storybook:components": "storybook dev -p 6001 -c ../components/.storybook",
    "storybook:blocks": "storybook dev -p 6002 -c ../blocks/.storybook",
    "storybook:cmsui": "storybook dev -p 6003 -c ../cmsui/.storybook",
    "storybook:publicui": "storybook dev -p 6004 -c ../publicui/.storybook",
    "storybook:layout": "storybook dev -p 6005 -c ../layout/.storybook",
    "storybook:main": "storybook dev -p 6060 -c .storybook",
    "build-storybook": "storybook build",
    "prettier:fix": "prettier --write '{apps,packages}/**/*.{js,jsx,ts,tsx}'",
    "lint:fix": "eslint --max-warnings=0 './**/*.{js,jsx,ts,tsx}' --fix --no-error-on-unmatched-pattern",
    "stylelint:fix": "sh -c 'if [ -f .stylelintrc ] || [ -f .stylelintrc.json ] || [ -f .stylelintrc.js ] || [ -f .stylelintrc.cjs ] || [ -f stylelint.config.js ] || [ -f stylelint.config.cjs ] || [ -f stylelint.config.mjs ]; then stylelint '''./**/*.{css,scss,less}''' --fix --allow-empty-input; else echo \"No local stylelint config, skipping\"; fi'",
    "format": "pnpm prettier:fix && pnpm lint:fix && pnpm stylelint:fix"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@platejs/playwright": "catalog:",
    "@playwright/test": "catalog:",
    "@plone/react-router": "workspace:*",
    "@storybook/addon-docs": "^9.1.7",
    "@storybook/addon-links": "^9.1.7",
    "@storybook/react-vite": "^9.1.7",
    "@types/react": "catalog:",
    "eslint": "^9.20.1",
    "eslint-config-prettier": "^10.0.1",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-better-tailwindcss": "^3.7.9",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.0.1",
    "eslint-plugin-storybook": "^9.1.7",
    "playwright": "catalog:",
    "prettier": "^3.5.2",
    "storybook": "^9.1.7",
    "stylelint": "^16.14.1",
    "stylelint-config-idiomatic-order": "10.0.0",
    "stylelint-prettier": "5.0.3",
    "tsconfig": "workspace:*",
    "typescript-eslint": "^8.41.0",
    "vite": "catalog:",
    "wait-on": "^8.0.0"
  }
}
