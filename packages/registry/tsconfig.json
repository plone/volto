{
  "extends": "tsconfig/react-library.json",
  "compilerOptions": {
    "strictPropertyInitialization": false,
    "paths": {}
  },
  "include": ["src/index.ts"],
  "exclude": [
    "node_modules",
    "build",
    "public",
    "coverage",
    "src/**/*.test.{js,jsx,ts,tsx}",
    "src/**/*.spec.{js,jsx,ts,tsx}",
    "src/**/*.stories.{js,jsx,ts,tsx}"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}
